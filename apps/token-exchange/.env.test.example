# Copy to .env or .env.test and fill in values.
# Used by scripts/test-live-api.ts to test the token-exchange flow against live APIs.
# All endpoints (exchange, templates, template/create, create-envelope) live on TOKEN_EXCHANGE_URL.

# Token-exchange base URL (e.g. https://sign-token.pinogy.com)
TOKEN_EXCHANGE_URL=https://sign-token.pinogy.com
# Secret for Authorization: Bearer when calling token-exchange endpoints
TOKEN_EXCHANGE_SECRET=

# Only needed when running the token-exchange server (it calls Documenso for templates/signing)
# DOCUMENSO_URL=https://sign.pinogy.com

# Exchange request body (slug + organisationId; optional: credentials for credential flow)
ORGANISATION_ID=
SLUG=

# Local PDF to upload as template (absolute or relative path)
PDF_PATH=

# Recipient for the envelope created from the template
RECIPIENT_EMAIL=

# Optional: signer name (default: Signer)
# RECIPIENT_NAME=Signer

# Optional: template and document title (default: filename or "Test envelope")
# TITLE=Test envelope
